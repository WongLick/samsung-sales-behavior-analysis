bal_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">SELECT 
  country,
  region,
  ROUND(SUM(is_returned) * 1.0 / SUM(units_sold), 3) AS return_rate
FROM samsung_sales
GROUP BY country, region
ORDER BY return_rate ASC
LIMIT 5;</sql><current_tab id="0"/></tab_sql></sqlb_project>
